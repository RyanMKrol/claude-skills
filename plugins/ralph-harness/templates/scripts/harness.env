# scripts/harness.env — optional project config, sourced by loop.sh.
#
# Every knob here is also overridable via the real environment. Precedence is:
#   real environment  >  this file  >  loop.sh built-in default
# (because of the `: "${VAR:=…}"` form — it only assigns when VAR is unset).
#
# Uncomment and edit what you want to pin. Defaults are sensible for most repos.

# ─── Model (pinned, never inherited) ─────────────────────────────────────────
# Pin the FULL model id — the bare alias (e.g. `opus`) drifts to "latest".
: "${MODEL:=claude-opus-4-8}"
# Reasoning effort: low|medium|high|xhigh|max. `high` = quality without max cost.
: "${EFFORT:=high}"

# ─── Caps & cadence ──────────────────────────────────────────────────────────
# Soft failures per task before the loop stops and asks a human.
: "${MAX_ATTEMPTS:=3}"
# Global iteration backstop within a single loop run.
: "${MAX_ITERS:=100}"
# Backoff (seconds) between retries and CI polls.
: "${WAIT_SECONDS:=30}"
# Max seconds to wait for a CI run to finish before treating it as indeterminate.
: "${CI_TIMEOUT:=1200}"

# ─── CI gate ─────────────────────────────────────────────────────────────────
# The GitHub Actions workflow the loop watches. MUST equal the `name:` in your
# .github/workflows/*.yml. The loop merges to main ONLY when this run is green.
: "${CI_WORKFLOW:=CI}"
# 1 = never merge without green CI (recommended). Set 0 only if the repo has no CI.
: "${REQUIRE_CI:=1}"
