# scripts/harness.env — optional project config, sourced by loop.sh.
#
# Every knob here is also overridable via the real environment. Precedence is:
#   real environment  >  this file  >  loop.sh built-in default
# (because of the `: "${VAR:=…}"` form — it only assigns when VAR is unset).
#
# Uncomment and edit what you want to pin. Defaults are sensible for most repos.

# ─── Model (pinned per task, never inherited) ────────────────────────────────
# These are the FALLBACK DEFAULT rung. Per-task precedence is:
#   TASKS.json task.model/.effort  >  TASKS.json defaults.model/.effort  >  these.
# Set per-task models in TASKS.json — a cheap model (e.g. claude-sonnet-4-6) for simple
# validation, Opus for coding/testing/reflection — plus an optional `escalation` ladder
# that bumps to a stronger model after repeated failure. These knobs just backstop a task
# that names neither. Pin the FULL model id — the bare alias (`opus`) drifts to "latest".
: "${MODEL:=claude-opus-4-8}"
# Reasoning effort: low|medium|high|xhigh|max. `high` = quality without max cost.
: "${EFFORT:=high}"
# NOTE: the loop parses TASKS.json with `jq` — it must be installed (e.g. `brew install jq`).

# ─── Caps & cadence ──────────────────────────────────────────────────────────
# Soft failures per task before the loop stops and asks a human.
: "${MAX_ATTEMPTS:=3}"
# Global iteration backstop within a single loop run.
: "${MAX_ITERS:=100}"
# Backoff (seconds) between retries and CI polls.
: "${WAIT_SECONDS:=30}"
# Max seconds to wait for a CI run to finish before treating it as indeterminate.
: "${CI_TIMEOUT:=1200}"

# ─── CI gate ─────────────────────────────────────────────────────────────────
# The GitHub Actions workflow the loop watches. MUST equal the `name:` in your
# .github/workflows/*.yml. The loop merges to main ONLY when this run is green.
: "${CI_WORKFLOW:=CI}"
# 1 = never merge without green CI (recommended). Set 0 only if the repo has no CI.
: "${REQUIRE_CI:=1}"

# ─── Integrate hook (optional) ───────────────────────────────────────────────
# A command run AFTER each task is integrated (CI green, marked done) — use it to
# refresh the running product so what's live matches main (deploy / restart a
# service / rebuild a preview). Runs from the repo root; failure is non-fatal.
# Examples:
#   : "${INTEGRATE_HOOK:=npm run deploy}"
#   : "${INTEGRATE_HOOK:=launchctl kickstart -k gui/$(id -u)/com.example.daemon}"
: "${INTEGRATE_HOOK:=}"

# ─── Rate / usage limits ─────────────────────────────────────────────────────
# When Claude hits a usage/session limit, the loop POLLS and resumes the SAME task
# (not a soft failure) — so it picks back up shortly after the quota resets rather
# than idling for hours. RL_POLL = how often to retry while limited (15 min);
# RL_MAX_WAIT = give up + exit (code 5) for supervise after this long limited (~6h).
# Both loop variants honour these.
: "${RL_POLL:=900}"
: "${RL_MAX_WAIT:=21600}"
# supervise.sh: the short cadence used INSTEAD of the normal interval after the loop
# gives up rate-limited (exit 5), so a quota reset is picked up within ~this long.
: "${RETRY_INTERVAL:=900}"
