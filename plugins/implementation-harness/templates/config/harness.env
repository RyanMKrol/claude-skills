# .harness/config/harness.env — optional project config, sourced by loop.sh.
#
# Every knob here is also overridable via the real environment. Precedence is:
#   real environment  >  this file  >  loop.sh built-in default
# (because of the `: "${VAR:=…}"` form — it only assigns when VAR is unset).
#
# Uncomment and edit what you want to pin. Defaults are sensible for most repos.

# ─── Cold-start difficulty floor ─────────────────────────────────────────────
# With difficulty auto-tuning the POLICY (facets.json + the escalation ledger) picks each
# task's STARTING tier and escalates UP the global tier ladder on failure. These knobs are
# only the COLD-START FLOOR — the tier a task starts at before the policy has data — so set
# them to the CHEAPEST tier (bias-cheap: start cheap, let the ladder escalate, learn).
# Pin the FULL model id — the bare alias (`opus`/`sonnet`) drifts to "latest".
: "${MODEL:=claude-haiku-4-5}"
# Reasoning effort: low|medium|high|xhigh|max, or leave EMPTY for a model with no effort
# parameter (e.g. the default floor, Haiku, which has none — the loop omits --effort entirely
# for it). If you raise the floor to a model that DOES support effort, set this too.
: "${EFFORT:=}"
# NOTE: the loop parses TASKS.json with `jq` — it must be installed (e.g. `brew install jq`).

# ─── Local Definition-of-Done gate (recommended) ─────────────────────────────
# A command run as a CHEAP, model-agnostic structural check BEFORE the paid audit and before the
# CI push — your project's real format/lint/test/build, exactly as CI runs it. A build that fails
# LOCAL_DOD is a failed attempt (discarded, cold-retried), so a broken build never reaches the
# auditor or main. Runs from the repo root; its output is captured to worklog/.local-dod.log and
# the tail is recorded in the failure ledger. Leave empty to skip (audit + CI still gate). Example:
#   : "${LOCAL_DOD:=npm run lint && npm test && npm run build}"
: "${LOCAL_DOD:=}"

# ─── Repo ────────────────────────────────────────────────────────────────────
# The integration branch the loop pushes to / fast-forwards. Override if yours isn't `main`.
# (The worktree variant also assumes origin/<this>.)
: "${MAIN_BRANCH:=main}"

# ─── Caps & cadence ──────────────────────────────────────────────────────────
# Soft failures per task before the loop stops and asks a human.
: "${MAX_ATTEMPTS:=2}"
# Global iteration backstop within a single loop run.
: "${MAX_ITERS:=100}"
# Backoff (seconds) between retries and CI polls.
: "${WAIT_SECONDS:=30}"
# Max seconds to wait for a CI run to finish before treating it as indeterminate.
: "${CI_TIMEOUT:=1200}"

# ─── CI gate ─────────────────────────────────────────────────────────────────
# The GitHub Actions workflow the loop watches. MUST equal the `name:` in your
# .github/workflows/*.yml. The loop merges to main ONLY when this run is green.
: "${CI_WORKFLOW:=CI}"
# 1 = never merge without green CI (recommended). Set 0 only if the repo has no CI.
: "${REQUIRE_CI:=1}"

# ─── Integrate hook (optional) ───────────────────────────────────────────────
# A command run AFTER each task is integrated (CI green, marked done) — use it to
# refresh the running product so what's live matches main (deploy / restart a
# service / rebuild a preview). Runs from the repo root; failure is non-fatal.
# Examples:
#   : "${INTEGRATE_HOOK:=npm run deploy}"
#   : "${INTEGRATE_HOOK:=launchctl kickstart -k gui/$(id -u)/com.example.daemon}"
: "${INTEGRATE_HOOK:=}"

# ─── More extension points live in .harness/custom/ (no knob here) ────────────
# Beyond these scalar knobs, the loop auto-discovers convention files under .harness/custom/:
#   • custom/hooks/on-<event>.sh — lifecycle hooks (drain/idle, blocked, exhausted, integrated),
#     each run as a NON-FATAL child process. Copy the shipped .example stubs to activate.
#   • custom/sensitive-paths.txt — extra APPEND-ONLY pre-push secret-guard patterns.
# See .harness/docs/HARNESS.md §8.3 "Extending via custom/". (on-integrated.sh complements the
# INTEGRATE_HOOK above — the hook file additionally gets the task id + verification as arguments.)

# ─── Sync the primary checkout when done (worktree variant only) ──────────────
# The worktree loop builds in an isolated sibling worktree and integrates by pushing
# to origin/main, so it never disturbs your primary checkout mid-run. When it FINISHES
# (backlog drained / idle), it leaves your primary checkout on the latest main so your
# local copy reflects everything that just landed. SAFE + best-effort: it skips a dirty
# tree (never clobbers uncommitted work), fast-forwards only, and is non-fatal.
# Set 0 to keep the strict "never touch the primary checkout" behavior. (No effect on
# the in-place variant, which already works directly on main.)
: "${SYNC_PRIMARY_ON_DONE:=1}"

# ─── Visual-verification hook (optional) ─────────────────────────────────────
# A command that captures the app's VISUAL output for a human/agent to eyeball, because
# tests/build can pass while the result is visibly wrong. NOT just browsers — anything you
# can capture works:
#   browser screenshot     : "${VISUAL_VERIFY_HOOK:=node scripts/visual-check.mjs}"
#   macOS desktop app      : "${VISUAL_VERIFY_HOOK:=screencapture -x /tmp/app.png}"
#   iOS simulator          : "${VISUAL_VERIFY_HOOK:=xcrun simctl io booted screenshot /tmp/app.png}"
#   generated image/chart  : "${VISUAL_VERIFY_HOOK:=npm run render -- --out /tmp/chart.png}"
# (See docs/designs/visual-verification.md for the rationale + worked per-platform examples.)
# Injected into the builder prompt (and, if sampled, the auditor prompt) when a task fires the check.
# A task fires it when a `"visualVerify": true` is set (any platform), OR — with no flag — the facets
# heuristic below matches. `"visualVerify": false` always suppresses. Empty hook = off (zero cost).
# Back-compat: the old UI_VERIFY_HOOK name is still honoured if this one is unset.
: "${VISUAL_VERIFY_HOOK:=${UI_VERIFY_HOOK:-}}"
# ── Facets heuristic (what auto-fires when a task has no explicit visualVerify flag) ──
# (a) INHERENTLY-visual work-types fire on ANY layer:
: "${VISUAL_VERIFY_WORKTYPES:=component style}"
# (b) else a task on one of these LAYERS fires — UNLESS its work-type is in the SKIP list below:
: "${VISUAL_VERIFY_LAYERS:=frontend}"
# work-types with no visual surface — never auto-fire even on a VISUAL_VERIFY_LAYERS layer:
: "${VISUAL_VERIFY_SKIP_WORKTYPES:=docs config logging}"
# (Maybe-visual work-types — bugfix / feature / migration on a non-frontend layer — are NOT auto-fired;
#  the add-to-backlog / convert-ideas skills ask/judge and set "visualVerify": true when warranted.)

# ─── Extra scope exemptions (optional) ────────────────────────────────────────
# Space-separated extra path prefixes structural_checks always allows a task to
# touch, on top of its own worklog + test files — e.g. a project-owned
# visual-verification script (like VISUAL_VERIFY_HOOK's own target) that legitimately
# needs updating alongside the change it verifies, without every such task
# having to declare it in `scope`. Leave empty to keep the gate fully strict.
: "${SCOPE_EXEMPT_GLOBS:=}"

# ─── Push cooldown (optional) ─────────────────────────────────────────────────
# Minimum wall-clock seconds between successful integration pushes to main. Exists
# for projects whose deploy webhook has its OWN rate limit (a rapid string of
# task-completion pushes can trip it even though each individual push is fine) —
# born from a real incident where this silently stopped deploys for hours.
# 0 (default) = off. Only the INTEGRATION push (the one that lands a task's code on
# main) is throttled; the status/ledger bookkeeping push that FOLLOWS each success is
# not (it's a separate [skip ci] commit) — a webhook that fires on every main push
# regardless of commit message will still see that second push.
: "${PUSH_COOLDOWN_SECONDS:=0}"

# ─── Dirty-tree self-heal (IN-PLACE VARIANT ONLY, optional) ──────────────────
# The in-place loop refuses to start if the checkout is dirty (it cold-resets
# between every attempt, which would discard uncommitted work). Set
# LOOP_AUTORESET=1 ONLY if this checkout is dedicated solely to the loop (never
# hand-edited) — then a dirty tree at startup is almost always orphaned partial
# work from an interrupted prior run, and the loop stashes it (recoverable via
# `git stash`) and self-heals instead of refusing. Default OFF: the worktree
# variant never needs this at all (its worktrees are always freshly torn down).
: "${LOOP_AUTORESET:=0}"

# ─── Dashboard (optional) ────────────────────────────────────────────────────
# The dashboard server reads these (real env > this file). FETCH_SECONDS > 0 makes the dashboard
# run `git fetch origin` on that interval so its freshness badge (and the backlog it renders) can't
# silently lag origin when the loop isn't running. Fetch-only — the dashboard never touches the
# working tree. 0 (default) = the dashboard only reports data age, never fetches.
: "${HARNESS_DASHBOARD_PORT:=4790}"
: "${HARNESS_DASHBOARD_FETCH_SECONDS:=0}"

# ─── Rate / usage limits ─────────────────────────────────────────────────────
# When Claude hits a usage/session limit the loop treats it as NOT a failure and resumes the SAME
# task cold. It first tries to PARSE the reset time out of Claude's own message ("resets 2:30pm
# (Europe/London)" / a relative "in 42 minutes" / an ISO timestamp) and sleeps until then + RL_BUFFER
# (capped at RL_BACKOFF_MAX). If nothing parses, the BUILD path backs off exponentially — first
# RL_BACKOFF_MIN, doubling to a cap of RL_EXP_MAX — while the (rarer) AUDIT path just polls every
# RL_POLL. RL_MAX_WAIT = give up + exit (code 5) for supervise after this long still limited (~6h),
# so a quota reset is picked up on the next cycle. Both loop variants honour these.
: "${RL_POLL:=900}"
: "${RL_MAX_WAIT:=21600}"
: "${RL_BACKOFF_MIN:=300}"
: "${RL_EXP_MAX:=3600}"
# Cap for a PARSED reset wait (~5h) — a known reset can legitimately be hours away.
: "${RL_BACKOFF_MAX:=18000}"
# Slack added on top of a PARSED reset time before re-attempting (a 5-min cushion — waking a hair
# too early immediately re-hits the same limit and burns the attempt).
: "${RL_BUFFER:=300}"
# supervise.sh: the short cadence used INSTEAD of the normal interval after the loop
# gives up rate-limited (exit 5), so a quota reset is picked up within ~this long.
: "${RETRY_INTERVAL:=900}"

# ─── Escalation-ladder resume across a loop.sh restart ──────────────────────
# A leftover worklog/.current.json heartbeat at process start (heartbeat_clear() runs only at a
# genuine terminal task outcome, not on every exit) is treated as a resumable mid-climb interruption
# rather than a fresh cold start — UNLESS it's older than this cap, in which case it's ignored as
# stale and the ladder cold-starts as before. Matches RL_MAX_WAIT's order of magnitude (~6h).
: "${LOOP_HEARTBEAT_RESUME_MAX_AGE:=21600}"
# One-shot escape hatch: set to 1 for a single run to force a clean, cold escalation-ladder restart,
# ignoring any leftover heartbeat (e.g. after a deliberate human intervention that wants a fresh start).
: "${LOOP_IGNORE_HEARTBEAT:=}"
