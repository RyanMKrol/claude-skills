# .harness/harness.env — optional project config, sourced by loop.sh.
#
# Every knob here is also overridable via the real environment. Precedence is:
#   real environment  >  this file  >  loop.sh built-in default
# (because of the `: "${VAR:=…}"` form — it only assigns when VAR is unset).
#
# Uncomment and edit what you want to pin. Defaults are sensible for most repos.

# ─── Cold-start difficulty floor ─────────────────────────────────────────────
# With difficulty auto-tuning the POLICY (facets.json + the escalation ledger) picks each
# task's STARTING tier and escalates UP the global tier ladder on failure. These knobs are
# only the COLD-START FLOOR — the tier a task starts at before the policy has data — so set
# them to the CHEAPEST tier (bias-cheap: start cheap, let the ladder escalate, learn).
# Pin the FULL model id — the bare alias (`opus`/`sonnet`) drifts to "latest".
: "${MODEL:=claude-sonnet-4-6}"
# Reasoning effort: low|medium|high|xhigh|max. Cheapest = low; the policy tunes up.
: "${EFFORT:=low}"
# NOTE: the loop parses TASKS.json with `jq` — it must be installed (e.g. `brew install jq`).

# ─── Caps & cadence ──────────────────────────────────────────────────────────
# Soft failures per task before the loop stops and asks a human.
: "${MAX_ATTEMPTS:=2}"
# Global iteration backstop within a single loop run.
: "${MAX_ITERS:=100}"
# Backoff (seconds) between retries and CI polls.
: "${WAIT_SECONDS:=30}"
# Max seconds to wait for a CI run to finish before treating it as indeterminate.
: "${CI_TIMEOUT:=1200}"

# ─── CI gate ─────────────────────────────────────────────────────────────────
# The GitHub Actions workflow the loop watches. MUST equal the `name:` in your
# .github/workflows/*.yml. The loop merges to main ONLY when this run is green.
: "${CI_WORKFLOW:=CI}"
# 1 = never merge without green CI (recommended). Set 0 only if the repo has no CI.
: "${REQUIRE_CI:=1}"

# ─── Integrate hook (optional) ───────────────────────────────────────────────
# A command run AFTER each task is integrated (CI green, marked done) — use it to
# refresh the running product so what's live matches main (deploy / restart a
# service / rebuild a preview). Runs from the repo root; failure is non-fatal.
# Examples:
#   : "${INTEGRATE_HOOK:=npm run deploy}"
#   : "${INTEGRATE_HOOK:=launchctl kickstart -k gui/$(id -u)/com.example.daemon}"
: "${INTEGRATE_HOOK:=}"

# ─── UI visual-verification hook (optional) ──────────────────────────────────
# A command that lets a human/agent VISUALLY confirm a UI change actually renders
# and behaves as intended — e.g. a screenshot script (see the PAGES/FLOWS pattern
# in docs/designs/ui-verification.md for a worked example). Injected into the
# builder prompt (and, if sampled, the auditor prompt) ONLY for tasks whose
# facets.workType is "component" — zero cost, zero new dependencies, for every
# other kind of task. Leave empty for projects with no browser UI.
: "${UI_VERIFY_HOOK:=}"

# ─── Extra scope exemptions (optional) ────────────────────────────────────────
# Space-separated extra path prefixes structural_checks always allows a task to
# touch, on top of its own worklog + test files — e.g. a project-owned UI
# visual-harness script (like UI_VERIFY_HOOK's own target) that legitimately
# needs updating alongside the UI change it verifies, without every such task
# having to declare it in `scope`. Leave empty to keep the gate fully strict.
: "${SCOPE_EXEMPT_GLOBS:=}"

# ─── Rate / usage limits ─────────────────────────────────────────────────────
# When Claude hits a usage/session limit, the loop POLLS and resumes the SAME task
# (not a soft failure) — so it picks back up shortly after the quota resets rather
# than idling for hours. RL_POLL = how often to retry while limited (15 min);
# RL_MAX_WAIT = give up + exit (code 5) for supervise after this long limited (~6h).
# Both loop variants honour these.
: "${RL_POLL:=900}"
: "${RL_MAX_WAIT:=21600}"
# supervise.sh: the short cadence used INSTEAD of the normal interval after the loop
# gives up rate-limited (exit 5), so a quota reset is picked up within ~this long.
: "${RETRY_INTERVAL:=900}"
